{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "graphql:codegen": "graphql-codegen --config codegen.ts",
        "graphql:generate": "pnpm graphql:schema && pnpm graphql:codegen",
        "graphql:schema": "php artisan graphql:schema-dump",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint resources/js",
        "format": "biome format --write resources/js && pnpm run typecheck",
        "test:frontend": "vitest run",
        "biome:upgrade": "biome migrate --write",
        "postinstall": "pnpm run biome:upgrade"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@graphql-codegen/cli": "^6.2.1",
        "@graphql-codegen/client-preset": "^5.2.4",
        "@graphql-typed-document-node/core": "^3.2.0",
        "@headlessui/react": "^2.2.9",
        "@inertiajs/react": "^2.3.18",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.2.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.0",
        "concurrently": "^9.2.1",
        "jsdom": "^28.1.0",
        "laravel-vite-plugin": "^2.1.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "@apollo/client": "^4.1.6",
        "graphql": "^16.13.1"
    }
}
